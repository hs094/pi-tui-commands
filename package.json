{
  "name": "pi-tui-commands",
  "type": "module",
  "version": "0.1.0",
  "description": "Interactive / command registry for pi — register any TUI tool as a slash command with binary-availability checks",
  "keywords": [
    "pi-package",
    "pi-extension",
    "tui",
    "lazygit",
    "interactive"
  ],
  "license": "MIT",
  "author": "Hardik Soni",
  "bugs": {
    "url": "https://github.com/hs094/pi-tui-commands/issues"
  },
  "homepage": "https://github.com/hs094/pi-tui-commands#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hs094/pi-tui-commands.git"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "pi": {
    "extensions": [
      "./extensions/tui-commands/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/hs094/pi-tui-commands/main/assets/menu.png"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": ">=0.79.0",
    "typebox": "*"
  },
  "scripts": {
    "check": "npm run typecheck && npm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "extensions/tui-commands/**"
  ],
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@earendil-works/pi-tui": "^0.79.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.9.5",
    "typebox": "^1.1.0",
    "typescript": "^5.8.0"
  }
}
